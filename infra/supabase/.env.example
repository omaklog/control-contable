# =============================================================================
# infra/supabase — Variables de Entorno del stack self-hosted
# =============================================================================
# Copiar este archivo a `.env` en este mismo directorio y completar con
# valores reales generados para EL SERVIDOR DEL DESPACHO.
# NUNCA commitear el archivo `.env` al repositorio (ya está en .gitignore
# mediante el patrón genérico `*.env`).
#
# Ver contracts/env-contract.md (en la especificación de esta feature) para
# el detalle de qué variables consumen además las apps `admin`/`portal`.
# =============================================================================

# -----------------------------------------------------------------------------
# Etiquetas de imagen (fijas, nunca "latest" — ver research.md §7).
# Conjunto verificado de versiones mutuamente compatibles (misma generación,
# mayo 2024), alineadas con Postgres 15 (mismo major_version que
# supabase/config.toml usado en el flujo de desarrollo local).
# -----------------------------------------------------------------------------
POSTGRES_IMAGE_TAG=15.1.1.47
KONG_IMAGE_TAG=2.8.1
GOTRUE_IMAGE_TAG=v2.151.0
POSTGREST_IMAGE_TAG=v12.0.3
STORAGE_API_IMAGE_TAG=v1.0.6
REALTIME_IMAGE_TAG=v2.28.36
POSTGRES_META_IMAGE_TAG=v0.80.1
STUDIO_IMAGE_TAG=20240506-2976cd6

# -----------------------------------------------------------------------------
# Base de datos (Postgres)
# -----------------------------------------------------------------------------
POSTGRES_DB=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Autenticación / JWT compartido entre servicios
# -----------------------------------------------------------------------------
# Generar con: openssl rand -base64 32
JWT_SECRET=change-me-jwt-secret-min-32-chars
JWT_EXPIRY=3600

# Llaves JWT firmadas con JWT_SECRET (roles "anon" y "service_role")
# Generar según la guía oficial de self-hosting de Supabase.
ANON_KEY=change-me-anon-key
SERVICE_ROLE_KEY=change-me-service-role-key

# -----------------------------------------------------------------------------
# Gateway (Kong) y Studio — puertos publicados SOLO en la interfaz
# interna/VPN·Tailscale del servidor (ver research.md §4, nunca 0.0.0.0 en WAN).
# BIND_ADDRESS es la IP de esa interfaz interna/VPN en el servidor del despacho;
# por defecto 127.0.0.1 para poder validar el stack en una máquina de prueba.
# -----------------------------------------------------------------------------
BIND_ADDRESS=127.0.0.1
KONG_API_PORT=8000
STUDIO_PORT=8082

# -----------------------------------------------------------------------------
# URLs usadas por Auth para construir enlaces de correo y validar redirecciones
# Ajustar al dominio/IP interno real del servidor del despacho.
# -----------------------------------------------------------------------------
SITE_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:8000
ADDITIONAL_REDIRECT_URLS=http://localhost:3000,http://localhost:3001

# -----------------------------------------------------------------------------
# Respaldos (ver contracts/backup-restore-cli.md)
# -----------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=30
BACKUP_OUTPUT_DIR=./backups
