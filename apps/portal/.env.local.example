# =============================================================================
# Portal — Variables de Entorno
# =============================================================================
# Copiar este archivo a .env.local y completar con los valores reales.
# NUNCA commitear el archivo .env.local al repositorio.
# Para obtener los valores locales: ejecutar `supabase status` después de
# `supabase start`.
# =============================================================================

# URL de la instancia de Supabase (local: http://localhost:54321)
# Expuesta al cliente — segura para incluir en el bundle del navegador
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Clave anónima de Supabase — segura para exponer al cliente
# Permite operaciones sujetas a Row Level Security (RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-status

# Clave de service role — SOLO SERVIDOR, NUNCA exponer al cliente
# Bypassa RLS — usar únicamente en Server Components y API Routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-status

# URL base de la aplicación portal (usada para redirecciones de auth)
NEXT_PUBLIC_APP_URL=http://localhost:3000
