# =============================================================================
# Admin — Variables de Entorno
# =============================================================================
# Copiar este archivo a .env.local y completar con los valores reales.
# NUNCA commitear el archivo .env.local al repositorio.
# Para obtener los valores locales: ejecutar `supabase status` después de
# `supabase start`.
# =============================================================================

# URL de la instancia de Supabase (misma instancia que el portal)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Clave anónima de Supabase — segura para exponer al cliente
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-status

# Clave de service role — SOLO SERVIDOR
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-status

# URL base del panel administrativo (puerto 3001)
NEXT_PUBLIC_APP_URL=http://localhost:3001
